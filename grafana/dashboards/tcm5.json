      "pluginVersion": "11.6.1",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH ev AS (\n  SELECT DISTINCT ON (coil_id, stand) coil_id, stand, anomaly_score,\n         p_electric, p_bearing, p_workroll, p_reduction, u_anomaly, u_votes\n  FROM scored_events\n  WHERE $__timeFilter(ts)\n  ORDER BY coil_id, stand, reading_id DESC\n),\nworst AS (\n  SELECT DISTINCT ON (coil_id) coil_id, stand AS worst_stand, anomaly_score,\n         CASE GREATEST(p_electric, p_bearing, p_workroll, p_reduction)\n              WHEN p_electric THEN 'electric'\n              WHEN p_bearing  THEN 'bearing'\n              WHEN p_workroll THEN 'workroll'\n              ELSE 'reduction'\n         END AS predicted_fault\n  FROM ev\n  ORDER BY coil_id, anomaly_score DESC\n),\nagg AS (\n  SELECT coil_id,\n         max(anomaly_score) AS max_score,\n         bool_or(u_anomaly) AS unsup_flag,\n         max(u_votes) AS u_votes,\n         count(*) FILTER (WHERE anomaly_score >= ${threshold}) AS stands_alarmed,\n         min(stand) FILTER (WHERE anomaly_score >= ${threshold}) AS first_stand\n  FROM ev\n  GROUP BY coil_id\n  HAVING max(anomaly_score) >= ${threshold} OR bool_or(u_anomaly)\n)\nSELECT a.coil_id AS \"coil\",\n       CASE WHEN a.max_score >= ${threshold} THEN w.predicted_fault ELSE 'unsupervised' END AS \"predicted fault\",\n       CASE WHEN a.max_score >= ${threshold} AND a.unsup_flag THEN 'model + ensemble'\n            WHEN a.max_score >= ${threshold} THEN 'model'\n            ELSE 'ensemble ' || a.u_votes || '/3'\n       END AS \"flagged by\",\n       round((w.anomaly_score * 100)::numeric, 1) AS \"confidence %\",\n       w.worst_stand AS \"worst stand\",\n       a.first_stand AS \"first flagged\",\n       a.stands_alarmed AS \"stands alarmed\"\nFROM agg a\nJOIN worst w USING (coil_id)\nORDER BY (a.max_score >= ${threshold}) DESC, a.max_score DESC NULLS LAST, a.u_votes DESC NULLS LAST\nLIMIT 50",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Coils to inspect",
      "type": "table"
    }
