# ---- TCM-5 real-time anomaly detection: compose configuration ----
# Distinct project name + port range so this stack coexists with any other
# Kafka/Flink/Grafana stacks already running on this machine.
COMPOSE_PROJECT_NAME=tcm5

# Start the full pipeline (incl. processor + producer) with a plain `docker compose up -d`,
# and stop it with `docker compose down` (add -v to also erase the data + model).
# Comment this out for infra-only ups.
COMPOSE_PROFILES=processor,producer

# Database / Grafana credentials (kept trivial for a local demo)
USERID=user
USERPWD=user

# Flink runtime image (PyFlink 1.18.1, Java 11) and cluster sizing
FLINK_IMAGE=fracorco/pyflink:1.18.1-scala_2.12-java11
FLINK_TASK_SLOTS=4
FLINK_DEFAULT_PARALLELISM=1

# Kafka topic the producer writes and the processor reads
TOPIC=tcm5_readings

# Producer pacing: SPEEDUP ~= coils/second. ~30 spreads the 120k coils over ~67 min (>1 hour),
# a relaxed, realistic cadence. Raise for a faster replay, lower for an even longer one.
# MAX_COILS=0 = all coils.
# Single shuffled input: the producer auto-detects data/tcm5_merged.parquet (faults
# interleaved across the whole run). If it is missing the producer rebuilds it from the
# six raw CSVs (same shared merge, seed 42); run `python scripts/merge_datasets.py` to
# build it ahead of time.
# PRODUCER_EXTRA appends raw flags, e.g. PRODUCER_EXTRA=--loop to replay continuously.
PRODUCER_SPEEDUP=30
PRODUCER_MAX_COILS=0
PRODUCER_EXTRA=

# Score threshold the Flink job uses for the windowed anomaly KPI (kept aligned with
# the dashboard's default $threshold).
KPI_THRESHOLD=0.85

# Auto-retrain policy in the retrain sidecar: watches live per-family recall and
# fires a retrain + hot-swap when a family the model never learned starts streaming.
# Set to 0 to drive retrains only via the button / POST /retrain.
RETRAIN_AUTO=1

# Host ports (left side of the mappings). Chosen to avoid the common defaults.
PORT_BROKER=39092
PORT_KAFKA_UI=38080
PORT_POSTGRES=35432
PORT_GRAFANA=33000
PORT_FLINK=38081
PORT_RETRAIN=38000
PORT_CONTROLROOM=38500
