# project name + 3xxxx host ports so this stack coexists with other Kafka/Flink/Grafana stacks
COMPOSE_PROJECT_NAME=tcm5

# comment out for infra-only ups (skips processor + producer)
COMPOSE_PROFILES=processor,producer

# local-only credentials
USERID=user
USERPWD=user

FLINK_IMAGE=fracorco/pyflink:1.18.1-scala_2.12-java11
FLINK_TASK_SLOTS=4
FLINK_DEFAULT_PARALLELISM=1

TOPIC=tcm5_readings

# SPEEDUP ~= coils/sec; 30 spreads 120k coils over ~67 min. MAX_COILS=0 = all.
# producer auto-detects data/tcm5_merged.parquet, else rebuilds it from the six raw CSVs (seed 42).
# PRODUCER_EXTRA appends raw flags, e.g. --loop to replay continuously.
PRODUCER_SPEEDUP=30
PRODUCER_MAX_COILS=0
PRODUCER_EXTRA=

# keep aligned with the dashboard's default $threshold
KPI_THRESHOLD=0.85

# 0 = retrain only via button / POST /retrain
RETRAIN_AUTO=1

# host ports
PORT_BROKER=39092
PORT_KAFKA_UI=38080
PORT_POSTGRES=35432
PORT_GRAFANA=33000
PORT_FLINK=38081
PORT_RETRAIN=38000
PORT_CONTROLROOM=38500
